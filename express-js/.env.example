# Configuration du serveur
PORT=5000
NODE_ENV=development

# Configuration MongoDB Atlas (distant)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority&appName=<appName>

# Configuration MongoDB Local (optionnel)
# MONGODB_URI=mongodb://localhost:27017/<database>

# CORS - Origine autorisée (frontend React)
CORS_ORIGIN=http://localhost:3000
