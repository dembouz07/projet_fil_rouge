{
  "id": null,
  "uid": "prometheus-health",
  "title": "Prometheus & Alerting Health",
  "tags": ["prometheus", "monitoring", "health"],
  "timezone": "browser",
  "editable": true,
  "panels": [
    {
      "id": 1,
      "title": "Target Status",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "up", "legendFormat": "{{job}}", "refId": "A"}
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "options": {"colorMode": "background", "graphMode": "none", "textMode": "value_and_name", "orientation": "horizontal"},
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"options": {"0": {"text": "DOWN", "color": "red"}}, "type": "value"},
            {"options": {"1": {"text": "UP", "color": "green"}}, "type": "value"}
          ]
        }
      }
    },
    {
      "id": 2,
      "title": "Scrape Duration",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "scrape_duration_seconds", "legendFormat": "{{job}}", "refId": "A"}
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 3,
      "title": "TSDB Symbol Table Size",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "prometheus_tsdb_symbol_table_size_bytes", "refId": "A"}
      ],
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 8},
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "id": 4,
      "title": "Prometheus Memory Usage",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "process_resident_memory_bytes{job=\"prometheus\"}", "refId": "A"}
      ],
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 8},
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "id": 5,
      "title": "Active Alerts (Firing)",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum(ALERTS{alertstate=\"firing\"})", "refId": "A"}
      ],
      "gridPos": {"h": 6, "w": 6, "x": 12, "y": 8},
      "fieldConfig": {
        "defaults": {
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]},
          "noValue": "0"
        }
      }
    },
    {
      "id": 6,
      "title": "Pending Alerts",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum(ALERTS{alertstate=\"pending\"})", "refId": "A"}
      ],
      "gridPos": {"h": 6, "w": 6, "x": 18, "y": 8},
      "fieldConfig": {
        "defaults": {
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}]},
          "noValue": "0"
        }
      }
    },
    {
      "id": 7,
      "title": "Alerts Over Time",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum(ALERTS{alertstate=\"firing\"})", "legendFormat": "Firing", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum(ALERTS{alertstate=\"pending\"})", "legendFormat": "Pending", "refId": "B"}
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14},
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10}
        }
      }
    },
    {
      "id": 8,
      "title": "Alertmanager Notifications",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "rate(alertmanager_notifications_total[5m])", "legendFormat": "{{integration}}", "refId": "A"}
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14},
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "id": 9,
      "title": "Rule Evaluation Duration",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "prometheus_rule_group_last_duration_seconds", "legendFormat": "{{rule_group}}", "refId": "A"}
      ],
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 22},
      "fieldConfig": {"defaults": {"unit": "s"}}
    }
  ],
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "10s",
  "schemaVersion": 38,
  "version": 1
}