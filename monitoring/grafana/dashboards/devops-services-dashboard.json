{
  "dashboard": {
    "id": null,
    "title": "DevOps Services - Jenkins, SonarQube, Portfolio",
    "tags": ["devops", "services", "blackbox"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Jenkins Status",
        "type": "stat",
        "targets": [
          {
            "expr": "probe_success{job=\"jenkins-http\"}",
            "format": "time_series",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 0},
        "options": {
          "colorMode": "background",
          "textMode": "name"
        },
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {"options": {"0": {"text": "DOWN", "color": "red"}}, "type": "value"},
              {"options": {"1": {"text": "UP", "color": "green"}}, "type": "value"}
            ],
            "noValue": "N/A"
          }
        }
      },
      {
        "id": 2,
        "title": "SonarQube Status",
        "type": "stat",
        "targets": [
          {
            "expr": "probe_success{job=\"sonarqube-http\"}",
            "format": "time_series",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0},
        "options": {
          "colorMode": "background",
          "textMode": "name"
        },
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {"options": {"0": {"text": "DOWN", "color": "red"}}, "type": "value"},
              {"options": {"1": {"text": "UP", "color": "green"}}, "type": "value"}
            ],
            "noValue": "N/A"
          }
        }
      },
      {
        "id": 3,
        "title": "Portfolio Status",
        "type": "stat",
        "targets": [
          {
            "expr": "probe_success{job=\"portfolio-http\"}",
            "format": "time_series",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0},
        "options": {
          "colorMode": "background",
          "textMode": "name"
        },
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {"options": {"0": {"text": "DOWN", "color": "red"}}, "type": "value"},
              {"options": {"1": {"text": "UP", "color": "green"}}, "type": "value"}
            ],
            "noValue": "N/A"
          }
        }
      },
      {
        "id": 4,
        "title": "Jenkins Response Time",
        "type": "stat",
        "targets": [
          {
            "expr": "probe_duration_seconds{job=\"jenkins-http\"}",
            "format": "time_series",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 6, "w": 8, "x": 0, "y": 8},
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 3},
                {"color": "red", "value": 5}
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "SonarQube Response Time",
        "type": "stat",
        "targets": [
          {
            "expr": "probe_duration_seconds{job=\"sonarqube-http\"}",
            "format": "time_series",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 6, "w": 8, "x": 8, "y": 8},
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 2},
                {"color": "red", "value": 3}
              ]
            }
          }
        }
      },
      {
        "id": 6,
        "title": "Portfolio Response Time",
        "type": "stat",
        "targets": [
          {
            "expr": "probe_duration_seconds{job=\"portfolio-http\"}",
            "format": "time_series",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 6, "w": 8, "x": 16, "y": 8},
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 2},
                {"color": "red", "value": 3}
              ]
            }
          }
        }
      },
      {
        "id": 7,
        "title": "Response Time History",
        "type": "timeseries",
        "targets": [
          {
            "expr": "probe_duration_seconds{job=\"jenkins-http\"}",
            "format": "time_series",
            "legendFormat": "Jenkins",
            "refId": "A"
          },
          {
            "expr": "probe_duration_seconds{job=\"sonarqube-http\"}",
            "format": "time_series",
            "legendFormat": "SonarQube",
            "refId": "B"
          },
          {
            "expr": "probe_duration_seconds{job=\"portfolio-http\"}",
            "format": "time_series",
            "legendFormat": "Portfolio",
            "refId": "C"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14},
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {"drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10}
          }
        }
      },
      {
        "id": 8,
        "title": "HTTP Phases Breakdown",
        "type": "timeseries",
        "targets": [
          {
            "expr": "probe_http_duration_seconds{job=~\".*-http\", phase=\"resolve\"}",
            "format": "time_series",
            "legendFormat": "{{job}} - DNS",
            "refId": "A"
          },
          {
            "expr": "probe_http_duration_seconds{job=~\".*-http\", phase=\"connect\"}",
            "format": "time_series",
            "legendFormat": "{{job}} - Connect",
            "refId": "B"
          },
          {
            "expr": "probe_http_duration_seconds{job=~\".*-http\", phase=\"processing\"}",
            "format": "time_series",
            "legendFormat": "{{job}} - Processing",
            "refId": "C"
          },
          {
            "expr": "probe_http_duration_seconds{job=~\".*-http\", phase=\"transfer\"}",
            "format": "time_series",
            "legendFormat": "{{job}} - Transfer",
            "refId": "D"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14},
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        }
      },
      {
        "id": 9,
        "title": "Service Uptime (%)",
        "type": "stat",
        "targets": [
          {
            "expr": "avg_over_time(probe_success{job=\"jenkins-http\"}[1h]) * 100",
            "format": "time_series",
            "legendFormat": "Jenkins",
            "refId": "A"
          },
          {
            "expr": "avg_over_time(probe_success{job=\"sonarqube-http\"}[1h]) * 100",
            "format": "time_series",
            "legendFormat": "SonarQube", 
            "refId": "B"
          },
          {
            "expr": "avg_over_time(probe_success{job=\"portfolio-http\"}[1h]) * 100",
            "format": "time_series",
            "legendFormat": "Portfolio",
            "refId": "C"
          }
        ],
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 22},
        "options": {
          "displayMode": "table",
          "orientation": "horizontal"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "steps": [
                {"color": "red", "value": null},
                {"color": "yellow", "value": 99},
                {"color": "green", "value": 99.9}
              ]
            }
          }
        }
      }
    ],
    "time": {"from": "now-1h", "to": "now"},
    "refresh": "10s",
    "schemaVersion": 37,
    "version": 1,
    "links": []
  }
}