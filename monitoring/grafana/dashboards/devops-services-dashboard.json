{
  "id": null,
  "uid": "devops-services",
  "title": "DevOps Services - Jenkins, SonarQube, Portfolio",
  "tags": ["devops", "services", "blackbox"],
  "timezone": "browser",
  "editable": true,
  "panels": [
    {
      "id": 1,
      "title": "Jenkins Status",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "probe_success{job=\"jenkins-http\"}", "refId": "A"}
      ],
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 0},
      "options": {"colorMode": "background", "graphMode": "none", "textMode": "value_and_name"},
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"options": {"0": {"text": "DOWN", "color": "red"}}, "type": "value"},
            {"options": {"1": {"text": "UP", "color": "green"}}, "type": "value"}
          ],
          "noValue": "N/A"
        }
      }
    },
    {
      "id": 2,
      "title": "SonarQube Status",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "probe_success{job=\"sonarqube-http\"}", "refId": "A"}
      ],
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0},
      "options": {"colorMode": "background", "graphMode": "none", "textMode": "value_and_name"},
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"options": {"0": {"text": "DOWN", "color": "red"}}, "type": "value"},
            {"options": {"1": {"text": "UP", "color": "green"}}, "type": "value"}
          ],
          "noValue": "N/A"
        }
      }
    },
    {
      "id": 3,
      "title": "Portfolio Status",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "probe_success{job=\"portfolio-http\"}", "refId": "A"}
      ],
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0},
      "options": {"colorMode": "background", "graphMode": "none", "textMode": "value_and_name"},
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"options": {"0": {"text": "DOWN", "color": "red"}}, "type": "value"},
            {"options": {"1": {"text": "UP", "color": "green"}}, "type": "value"}
          ],
          "noValue": "N/A"
        }
      }
    },
    {
      "id": 4,
      "title": "Jenkins Response Time",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "probe_duration_seconds{job=\"jenkins-http\"}", "refId": "A"}
      ],
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 8},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 3}, {"color": "red", "value": 5}]}
        }
      }
    },
    {
      "id": 5,
      "title": "SonarQube Response Time",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "probe_duration_seconds{job=\"sonarqube-http\"}", "refId": "A"}
      ],
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 8},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 2}, {"color": "red", "value": 3}]}
        }
      }
    },
    {
      "id": 6,
      "title": "Portfolio Response Time",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "probe_duration_seconds{job=\"portfolio-http\"}", "refId": "A"}
      ],
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 8},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 2}, {"color": "red", "value": 3}]}
        }
      }
    },
    {
      "id": 7,
      "title": "Response Time History",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "probe_duration_seconds{job=\"jenkins-http\"}", "legendFormat": "Jenkins", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "probe_duration_seconds{job=\"sonarqube-http\"}", "legendFormat": "SonarQube", "refId": "B"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "probe_duration_seconds{job=\"portfolio-http\"}", "legendFormat": "Portfolio", "refId": "C"}
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {"drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10}
        }
      }
    },
    {
      "id": 8,
      "title": "HTTP Phases Breakdown",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "probe_http_duration_seconds{phase=\"resolve\"}", "legendFormat": "{{job}} - DNS", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "probe_http_duration_seconds{phase=\"connect\"}", "legendFormat": "{{job}} - Connect", "refId": "B"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "probe_http_duration_seconds{phase=\"processing\"}", "legendFormat": "{{job}} - Processing", "refId": "C"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "probe_http_duration_seconds{phase=\"transfer\"}", "legendFormat": "{{job}} - Transfer", "refId": "D"}
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14},
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 9,
      "title": "Service Uptime (%)",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "avg_over_time(probe_success{job=\"jenkins-http\"}[1h]) * 100", "legendFormat": "Jenkins", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "avg_over_time(probe_success{job=\"sonarqube-http\"}[1h]) * 100", "legendFormat": "SonarQube", "refId": "B"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "avg_over_time(probe_success{job=\"portfolio-http\"}[1h]) * 100", "legendFormat": "Portfolio", "refId": "C"}
      ],
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 22},
      "options": {"colorMode": "value", "graphMode": "none", "textMode": "value_and_name", "orientation": "horizontal"},
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 99}, {"color": "green", "value": 99.9}]}
        }
      }
    }
  ],
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "10s",
  "schemaVersion": 38,
  "version": 1
}